{
  "name": "banisa-medical-platform",
  "version": "1.0.0",
  "description": "Banisa Medical Booking Platform - Full Stack Application",
  "private": true,
  "workspaces": [
    "backend",
    "code"
  ],
  "scripts": {
    "install:all": "cd backend && npm install && cd ../code && npm install",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd code && npm install",
    "build": "cd code && npm run build && cd ../backend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd code && npm run build",
    "start": "cd backend && npm start",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd code && npm run preview",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd code && npm run dev"
  },
  "engines": {
    "node": "18.19.1",
    "npm": ">=9.0.0"
  },
  "author": "",
  "license": "ISC"
}