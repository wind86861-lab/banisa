generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  phone              String              @unique
  email              String?
  passwordHash       String
  firstName          String?
  lastName           String?
  role               Role                @default(PATIENT)
  status             UserStatus          @default(PENDING)
  isActive           Boolean             @default(true)
  clinicId           String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  appointments       Appointment[]
  diagnosticServices DiagnosticService[] @relation("CreatedBy")
  reviews            Review[]
  sanatoriumServices SanatoriumService[] @relation("SanatoriumCreatedBy")
  serviceReviews     ServiceReview[]
  surgicalServices   SurgicalService[]   @relation("SurgicalCreatedBy")

  @@index([phone])
  @@index([status])
  @@index([role])
}

model ServiceCategory {
  id                 String              @id @default(uuid())
  parentId           String?
  level              Int                 @default(0)
  nameUz             String
  nameRu             String?
  nameEn             String?
  slug               String              @unique
  icon               String?
  sortOrder          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  diagnosticServices DiagnosticService[]
  sanatoriumServices SanatoriumService[]
  parent             ServiceCategory?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children           ServiceCategory[]   @relation("CategoryHierarchy")
  surgicalServices   SurgicalService[]
}

model DiagnosticService {
  id                    String                    @id @default(uuid())
  nameUz                String
  nameRu                String?
  nameEn                String?
  categoryId            String
  shortDescription      String?                   @db.VarChar(200)
  fullDescription       String?
  priceRecommended      Int                       @default(0)
  priceMin              Int                       @default(0)
  priceMax              Int                       @default(0)
  durationMinutes       Int                       @default(30)
  resultTimeHours       Float                     @default(24)
  preparation           String?
  contraindications     String?
  sampleType            String?                   @db.VarChar(100)
  imageUrl              String?
  isActive              Boolean                   @default(true)
  createdById           String
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  additionalInfo        Json?
  bookingPolicy         Json?
  contraindicationsJson Json?
  indicationsJson       Json?
  preparationJson       Json?
  processDescription    String?
  resultFormat          String?                   @db.VarChar(200)
  resultParameters      Json?
  sampleVolume          String?                   @db.VarChar(50)
  appointments          Appointment[]             @relation("DiagnosticServiceAppointments")
  clinicLinks           ClinicDiagnosticService[] @relation("DiagnosticServiceClinicLinks")
  category              ServiceCategory           @relation(fields: [categoryId], references: [id])
  createdBy             User                      @relation("CreatedBy", fields: [createdById], references: [id])
  serviceReviews        ServiceReview[]

  @@index([categoryId])
  @@index([isActive])
  @@index([priceRecommended])
}

model SurgicalService {
  id                        String                  @id @default(uuid())
  nameUz                    String
  nameRu                    String?
  nameEn                    String?
  categoryId                String
  shortDescription          String?                 @db.VarChar(200)
  fullDescription           String?
  imageUrl                  String?
  priceRecommended          Int
  priceMin                  Int
  priceMax                  Int
  durationMinutes           Int                     @default(0)
  minDuration               Int?
  maxDuration               Int?
  recoveryDays              Int                     @default(0)
  anesthesiaType            AnesthesiaType
  anesthesiaNotes           String?
  requiresHospitalization   Boolean                 @default(true)
  hospitalizationDays       Int?
  roomType                  RoomType?
  requiresICU               Boolean                 @default(false)
  icuDays                   Int?
  hospitalizationNotes      String?
  requiredTests             Json?
  preparationFasting        Boolean                 @default(false)
  fastingHours              Int?
  preparationMedication     String?
  preparationRestrictions   Json?
  preparationTimeline       String?
  contraindicationsAbsolute Json?
  contraindicationsRelative Json?
  complexity                Complexity
  riskLevel                 RiskLevel
  minSurgeonExperience      Int                     @default(0)
  surgeonQualifications     Json?
  surgeonSpecialization     String?
  requiredEquipment         Json?
  operationStages           Json?
  postOpImmediate           Json?
  postOpHome                Json?
  followUpSchedule          Json?
  recoveryMilestones        Json?
  packageIncluded           Json?
  packageExcluded           Json?
  alternatives              Json?
  faqs                      Json?
  successRate               Float?
  videoUrl                  String?
  isActive                  Boolean                 @default(true)
  createdById               String
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  appointments              Appointment[]           @relation("SurgicalServiceAppointments")
  clinicLinks               ClinicSurgicalService[] @relation("SurgicalServiceClinicLinks")
  serviceReviews            ServiceReview[]
  category                  ServiceCategory         @relation(fields: [categoryId], references: [id])
  createdBy                 User                    @relation("SurgicalCreatedBy", fields: [createdById], references: [id])

  @@index([categoryId])
  @@index([isActive])
  @@index([complexity])
  @@index([riskLevel])
}

model Clinic {
  id                 String                    @id @default(uuid())
  nameUz             String
  nameRu             String?
  nameEn             String?
  type               ClinicType                @default(GENERAL)
  status             ClinicStatus              @default(PENDING)
  description        String?
  logo               String?
  coverImage         String?
  region             String
  district           String
  street             String
  apartment          String?
  landmark           String?
  latitude           Float?
  longitude          Float?
  phones             Json                      @default("[]")
  emails             Json                      @default("[]")
  website            String?
  socialMedia        Json?
  workingHours       Json                      @default("[]")
  hasEmergency       Boolean                   @default(false)
  hasAmbulance       Boolean                   @default(false)
  hasOnlineBooking   Boolean                   @default(true)
  bedsCount          Int?
  floorsCount        Int?
  parkingAvailable   Boolean                   @default(false)
  amenities          Json?
  paymentMethods     Json?
  insuranceAccepted  Json?
  priceRange         String?
  averageRating      Float?                    @default(0)
  reviewCount        Int                       @default(0)
  registrationNumber String?
  taxId              String?
  licenseNumber      String?
  licenseIssuedAt    DateTime?
  licenseExpiresAt   DateTime?
  licenseIssuedBy    String?
  adminFirstName     String?
  adminLastName      String?
  adminEmail         String?
  adminPhone         String?
  adminPosition      String?
  rejectionReason    String?
  notes              String?
  approvedById       String?
  isActive           Boolean                   @default(true)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  createdBy          String?
  pendingPersons     Json?
  reviewedAt         DateTime?
  reviewedBy         String?
  source             ClinicSource              @default(ADMIN_CREATED)
  submittedAt        DateTime?
  appointments       Appointment[]
  checkupPackages    ClinicCheckupPackage[]
  diagnosticServices ClinicDiagnosticService[]
  sanatoriumServices ClinicSanatoriumService[]
  surgicalServices   ClinicSurgicalService[]
  doctors            Doctor[]
  reviews            Review[]

  @@index([status])
  @@index([source])
  @@index([region])
  @@index([type])
  @@index([createdAt])
}

model Doctor {
  id           String        @id @default(uuid())
  clinicId     String
  firstName    String
  lastName     String
  specialty    String?
  bio          String?
  photoUrl     String?
  phone        String?
  email        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  clinic       Clinic        @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
  @@index([isActive])
}

model Appointment {
  id                  String                 @id @default(uuid())
  clinicId            String
  patientId           String
  doctorId            String?
  serviceType         AppointmentServiceType @default(OTHER)
  diagnosticServiceId String?
  surgicalServiceId   String?
  scheduledAt         DateTime
  status              AppointmentStatus      @default(PENDING)
  price               Int                    @default(0)
  notes               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  clinic              Clinic                 @relation(fields: [clinicId], references: [id])
  diagnosticService   DiagnosticService?     @relation("DiagnosticServiceAppointments", fields: [diagnosticServiceId], references: [id])
  doctor              Doctor?                @relation(fields: [doctorId], references: [id])
  patient             User                   @relation(fields: [patientId], references: [id])
  surgicalService     SurgicalService?       @relation("SurgicalServiceAppointments", fields: [surgicalServiceId], references: [id])

  @@index([clinicId])
  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([scheduledAt])
}

model Review {
  id        String   @id @default(uuid())
  clinicId  String
  userId    String
  rating    Float
  comment   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([clinicId, userId])
  @@index([clinicId])
  @@index([userId])
  @@index([rating])
  @@index([isActive])
}

model ServiceReview {
  id                  String             @id @default(uuid())
  userId              String
  diagnosticServiceId String?
  surgicalServiceId   String?
  sanatoriumServiceId String?
  rating              Int
  comment             String?
  status              ReviewStatus       @default(PENDING)
  reviewedBy          String?
  reviewedAt          DateTime?
  rejectionReason     String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  diagnosticService   DiagnosticService? @relation(fields: [diagnosticServiceId], references: [id])
  sanatoriumService   SanatoriumService? @relation(fields: [sanatoriumServiceId], references: [id])
  surgicalService     SurgicalService?   @relation(fields: [surgicalServiceId], references: [id])
  user                User               @relation(fields: [userId], references: [id])

  @@index([diagnosticServiceId])
  @@index([surgicalServiceId])
  @@index([sanatoriumServiceId])
  @@index([userId])
  @@index([status])
  @@index([rating])
  @@index([createdAt])
}

model ClinicDiagnosticService {
  clinicId            String
  diagnosticServiceId String
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  id                  String                @id @default(uuid())
  clinic              Clinic                @relation(fields: [clinicId], references: [id])
  diagnosticService   DiagnosticService     @relation("DiagnosticServiceClinicLinks", fields: [diagnosticServiceId], references: [id])
  customization       ServiceCustomization?

  @@unique([clinicId, diagnosticServiceId])
  @@index([clinicId])
  @@index([diagnosticServiceId])
  @@index([isActive])
}

model ServiceCustomization {
  id                       String                  @id @default(uuid())
  clinicServiceId          String                  @unique
  customNameUz             String?
  customNameRu             String?
  customDescriptionUz      String?
  customDescriptionRu      String?
  benefits                 Json?
  preparationUz            String?
  preparationRu            String?
  customCategory           String?
  tags                     String[]
  estimatedDurationMinutes Int?
  availableDays            String[]
  availableTimeSlots       Json?
  requiresAppointment      Boolean                 @default(true)
  requiresPrepayment       Boolean                 @default(false)
  prepaymentPercentage     Int?
  isHighlighted            Boolean                 @default(false)
  displayOrder             Int?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  customPrice              Int?
  discountPercent          Int?
  accuracy                 String?                 @db.VarChar(50)
  additionalInfo           Json?
  bookingPolicy            Json?
  certifications           Json?
  equipment                String?                 @db.VarChar(200)
  fullDescriptionRu        String?
  fullDescriptionUz        String?
  preparationJson          Json?
  processDescription       String?
  resultFormat             String?                 @db.VarChar(200)
  resultTimeHours          Float?
  sampleVolume             String?                 @db.VarChar(50)
  clinicService            ClinicDiagnosticService @relation(fields: [clinicServiceId], references: [id], onDelete: Cascade)
  images                   ServiceImage[]

  @@index([clinicServiceId])
  @@index([customCategory])
  @@index([isHighlighted])
  @@index([displayOrder])
}

model ServiceImage {
  id              String               @id @default(uuid())
  customizationId String
  url             String
  alt             String?
  order           Int                  @default(0)
  isPrimary       Boolean              @default(false)
  uploadedAt      DateTime             @default(now())
  customization   ServiceCustomization @relation(fields: [customizationId], references: [id], onDelete: Cascade)

  @@index([customizationId])
  @@index([order])
  @@index([isPrimary])
}

model ClinicSurgicalService {
  clinicId          String
  surgicalServiceId String
  isActive          Boolean         @default(true)
  customizationData Json?
  serviceImages     Json?
  createdAt         DateTime        @default(now())
  clinic            Clinic          @relation(fields: [clinicId], references: [id])
  surgicalService   SurgicalService @relation("SurgicalServiceClinicLinks", fields: [surgicalServiceId], references: [id])

  @@id([clinicId, surgicalServiceId])
  @@index([clinicId])
  @@index([surgicalServiceId])
  @@index([isActive])
}

model CheckupPackage {
  id               String                 @id @default(cuid())
  nameUz           String
  nameRu           String?
  nameEn           String?
  slug             String                 @unique
  category         CheckupCategory
  shortDescription String?                @db.VarChar(200)
  fullDescription  String?
  targetAudience   String?                @db.VarChar(100)
  recommendedPrice Int
  priceMin         Int
  priceMax         Int
  discount         Int?
  imageUrl         String?
  isActive         Boolean                @default(true)
  createdById      String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  items            CheckupPackageItem[]
  clinicPackages   ClinicCheckupPackage[]

  @@index([category])
  @@index([isActive])
  @@index([slug])
}

model CheckupPackageItem {
  id                  String         @id @default(cuid())
  packageId           String
  diagnosticServiceId String
  serviceName         String
  servicePrice        Int
  quantity            Int            @default(1)
  isRequired          Boolean        @default(true)
  notes               String?        @db.VarChar(255)
  sortOrder           Int            @default(0)
  package             CheckupPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@index([diagnosticServiceId])
}

model ClinicCheckupPackage {
  id           String         @id @default(cuid())
  clinicId     String
  packageId    String
  clinicPrice  Int
  customNotes  String?
  isActive     Boolean        @default(true)
  bookingCount Int            @default(0)
  activatedAt  DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  clinic       Clinic         @relation(fields: [clinicId], references: [id])
  package      CheckupPackage @relation(fields: [packageId], references: [id])

  @@unique([clinicId, packageId])
  @@index([clinicId])
  @@index([packageId])
  @@index([isActive])
}

model SanatoriumService {
  id                String                    @id @default(uuid())
  nameUz            String
  nameRu            String?
  nameEn            String?
  categoryId        String
  shortDescription  String?                   @db.VarChar(200)
  fullDescription   String?
  imageUrl          String?
  serviceType       SanatoriumServiceType
  priceRecommended  Int                       @default(0)
  priceMin          Int                       @default(0)
  priceMax          Int                       @default(0)
  pricePer          String                    @default("session")
  durationMinutes   Int                       @default(0)
  durationDays      Int?
  sessionsCount     Int?
  capacity          Int?
  includes          Json?
  contraindications String?
  preparation       String?
  isActive          Boolean                   @default(true)
  createdById       String
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  clinicLinks       ClinicSanatoriumService[] @relation("SanatoriumServiceClinicLinks")
  category          ServiceCategory           @relation(fields: [categoryId], references: [id])
  createdBy         User                      @relation("SanatoriumCreatedBy", fields: [createdById], references: [id])
  serviceReviews    ServiceReview[]

  @@index([categoryId])
  @@index([isActive])
  @@index([serviceType])
}

model ClinicSanatoriumService {
  clinicId            String
  sanatoriumServiceId String
  clinicPrice         Int?
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  availableFrom       DateTime?
  availableTo         DateTime?
  contactEmail        String?
  contactPhone        String?
  customDescription   String?
  customNameRu        String?
  customNameUz        String?
  discountPercent     Int?              @default(0)
  discountValidUntil  DateTime?
  excludes            Json?
  features            Json?
  includes            Json?
  locationAddress     String?
  locationCoords      String?
  maxGuests           Int?
  mealDescription     String?
  mealPlan            String?
  roomAmenities       Json?
  roomImages          Json?
  roomType            String?
  updatedAt           DateTime?         @updatedAt
  clinic              Clinic            @relation(fields: [clinicId], references: [id])
  sanatoriumService   SanatoriumService @relation("SanatoriumServiceClinicLinks", fields: [sanatoriumServiceId], references: [id])

  @@id([clinicId, sanatoriumServiceId])
  @@index([clinicId])
  @@index([sanatoriumServiceId])
  @@index([isActive])
}

model ClinicRegistrationRequest {
  id                String                     @id @default(uuid())
  status            RegistrationStatus         @default(PENDING)
  nameUz            String
  nameRu            String?
  nameEn            String?
  clinicType        String
  foundedYear       Int?
  descriptionUz     String
  descriptionRu     String?
  logoUrl           String?
  regionId          String
  districtId        String
  streetAddress     String
  addressUz         String
  addressRu         String?
  zipCode           String?
  googleMapsUrl     String?
  landmark          String?
  latitude          Float?
  longitude         Float?
  primaryPhone      String
  secondaryPhone    String?
  emergencyPhone    String?
  email             String
  website           String?
  telegram          String?
  instagram         String?
  facebook          String?
  youtube           String?
  workingHours      Json
  isAlwaysOpen      Boolean                    @default(false)
  lunchBreakStart   String?
  lunchBreakEnd     String?
  holidayNotes      String?
  selectedServices  Json                       @default("[]")
  licenseUrl        String?
  licenseNumber     String
  licenseExpiry     String
  inn               String
  legalName         String
  legalAddress      String
  legalForm         String?
  certificates      Json                       @default("[]")
  bankName          String
  bankAccountNumber String
  mfo               String
  oked              String?
  vatNumber         String?
  paymentMethods    Json                       @default("[]")
  invoiceEmail      String?
  rejectionReason   String?
  reviewedById      String?
  reviewedAt        DateTime?
  notes             String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  persons           ClinicRegistrationPerson[]

  @@index([status])
}

model PaymeTransaction {
  id          String   @id @default(uuid())
  paymeId     String?  @unique
  paymeTime   BigInt?
  createTime  BigInt?
  performTime BigInt?
  cancelTime  BigInt?
  amount      Int
  state       Int      @default(1)
  reason      Int?
  orderId     String
  orderType   String   @default("appointment")
  receivers   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([paymeId])
  @@index([orderId])
  @@index([state])
}

model ClinicRegistrationPerson {
  id           String                    @id @default(uuid())
  requestId    String
  firstName    String
  lastName     String
  middleName   String?
  position     String
  phone        String
  email        String?
  passwordHash String
  isPrimary    Boolean                   @default(false)
  createdAt    DateTime                  @default(now())
  request      ClinicRegistrationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([phone])
}

model HomepageSettings {
  id        String   @id @default(uuid())
  section   String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  CLINIC_ADMIN
  PATIENT
  PENDING_CLINIC
}

enum UserStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AnesthesiaType {
  LOCAL
  GENERAL
  SPINAL
  SEDATION
}

enum RoomType {
  STANDARD
  COMFORT
  LUX
  VIP
}

enum Complexity {
  SIMPLE
  MEDIUM
  COMPLEX
  ADVANCED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ClinicSource {
  ADMIN_CREATED
  SELF_REGISTERED
}

enum ClinicStatus {
  PENDING
  APPROVED
  REJECTED
  BLOCKED
  IN_REVIEW
  SUSPENDED
  DELETED
}

enum ClinicType {
  GENERAL
  SPECIALIZED
  DIAGNOSTIC
  DENTAL
  MATERNITY
  REHABILITATION
  PHARMACY
  OTHER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AppointmentServiceType {
  DIAGNOSTIC
  SURGICAL
  OTHER
}

enum CheckupCategory {
  BASIC
  SPECIALIZED
  AGE_BASED
}

enum SanatoriumServiceType {
  ACCOMMODATION
  MEDICAL
  NUTRITION
  PROGRAM
}

enum RegistrationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}
